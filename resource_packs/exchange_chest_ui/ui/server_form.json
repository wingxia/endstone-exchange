{
  "namespace": "server_form",
  "long_form@common_dialogs.main_panel_no_buttons": {
    "$title_panel": "common_dialogs.standard_title_label",
    "$title_size": ["100% - 15px", 10],
    "$title_max_size": ["100% - 15px", 10],
    "size": [520, 300],
    "$text_name": "#title_text",
    "$title_text_binding_type": "none",
    "$child_control": "server_form.exchange_form_panel",
    "layer": 2
  },
  "exchange_form_panel": {
    "type": "panel",
    "size": ["100%", "100%"],
    "controls": [
      {
        "category_slots@server_form.exchange_category_slots": {
          "offset": [8, 8]
        }
      },
      {
        "product_slots@server_form.exchange_product_slots": {
          "offset": [90, 8]
        }
      },
      {
        "quote_panel@server_form.exchange_quote_panel": {
          "offset": [356, 8]
        }
      },
      {
        "tool_slots@server_form.exchange_tool_slots": {
          "offset": [356, 135]
        }
      },
      {
        "trade_slots@server_form.exchange_trade_slots": {
          "offset": [356, 214]
        }
      }
    ]
  },
  "exchange_category_slots": {
    "type": "stack_panel",
    "size": [74, 252],
    "orientation": "vertical",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "collection_name": "form_buttons",
    "controls": [
      {"cat_0@server_form.exchange_side_button": {"collection_index": 0}},
      {"cat_1@server_form.exchange_side_button": {"collection_index": 1}},
      {"cat_2@server_form.exchange_side_button": {"collection_index": 2}},
      {"cat_3@server_form.exchange_side_button": {"collection_index": 3}},
      {"cat_4@server_form.exchange_side_button": {"collection_index": 4}},
      {"cat_5@server_form.exchange_side_button": {"collection_index": 5}},
      {"cat_6@server_form.exchange_side_button": {"collection_index": 6}},
      {"cat_7@server_form.exchange_side_button": {"collection_index": 7}},
      {"cat_8@server_form.exchange_side_button": {"collection_index": 8}}
    ]
  },
  "exchange_product_slots": {
    "type": "grid",
    "size": [256, 252],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "grid_dimensions": [4, 7],
    "collection_name": "form_buttons",
    "controls": [
      {"p_0@server_form.exchange_product_button": {"grid_position": [0, 0], "collection_index": 9}},
      {"p_1@server_form.exchange_product_button": {"grid_position": [1, 0], "collection_index": 10}},
      {"p_2@server_form.exchange_product_button": {"grid_position": [2, 0], "collection_index": 11}},
