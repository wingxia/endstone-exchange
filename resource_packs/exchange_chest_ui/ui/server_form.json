      {"p_6@server_form.exchange_product_button": {"grid_position": [2, 1], "collection_index": 15}},
      {"p_7@server_form.exchange_product_button": {"grid_position": [3, 1], "collection_index": 16}},
      {"p_8@server_form.exchange_product_button": {"grid_position": [0, 2], "collection_index": 17}},
      {"p_9@server_form.exchange_product_button": {"grid_position": [1, 2], "collection_index": 18}},
      {"p_10@server_form.exchange_product_button": {"grid_position": [2, 2], "collection_index": 19}},
      {"p_11@server_form.exchange_product_button": {"grid_position": [3, 2], "collection_index": 20}},
      {"p_12@server_form.exchange_product_button": {"grid_position": [0, 3], "collection_index": 21}},
      {"p_13@server_form.exchange_product_button": {"grid_position": [1, 3], "collection_index": 22}},
      {"p_14@server_form.exchange_product_button": {"grid_position": [2, 3], "collection_index": 23}},
      {"p_15@server_form.exchange_product_button": {"grid_position": [3, 3], "collection_index": 24}},
      {"p_16@server_form.exchange_product_button": {"grid_position": [0, 4], "collection_index": 25}},
      {"p_17@server_form.exchange_product_button": {"grid_position": [1, 4], "collection_index": 26}},
      {"p_18@server_form.exchange_product_button": {"grid_position": [2, 4], "collection_index": 27}},
      {"p_19@server_form.exchange_product_button": {"grid_position": [3, 4], "collection_index": 28}},
      {"p_20@server_form.exchange_product_button": {"grid_position": [0, 5], "collection_index": 29}},
      {"p_21@server_form.exchange_product_button": {"grid_position": [1, 5], "collection_index": 30}},
      {"p_22@server_form.exchange_product_button": {"grid_position": [2, 5], "collection_index": 31}},
      {"p_23@server_form.exchange_product_button": {"grid_position": [3, 5], "collection_index": 32}},
      {"p_24@server_form.exchange_product_button": {"grid_position": [0, 6], "collection_index": 33}},
      {"p_25@server_form.exchange_product_button": {"grid_position": [1, 6], "collection_index": 34}},
      {"p_26@server_form.exchange_product_button": {"grid_position": [2, 6], "collection_index": 35}},
      {"p_27@server_form.exchange_product_button": {"grid_position": [3, 6], "collection_index": 36}}
    ]
  },
  "exchange_quote_panel": {
    "type": "panel",
    "size": [154, 120],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "controls": [
      {
        "quote_text": {
          "type": "label",
          "size": ["100%", "100%"],
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "color": "$main_header_text_color",
          "font_size": "small",
          "font_scale_factor": 0.78,
          "line_padding": 0,
          "text": "#form_text",
          "bindings": [
            {
              "binding_name": "#form_text"
            }
          ]
        }
      }
    ]
  },
  "exchange_tool_slots": {
    "type": "grid",
    "size": [154, 70],
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "grid_dimensions": [2, 4],
    "collection_name": "form_buttons",
    "controls": [
      {"tool_0@server_form.exchange_tool_button": {"grid_position": [0, 0], "collection_index": 37}},
      {"tool_1@server_form.exchange_tool_button": {"grid_position": [1, 0], "collection_index": 38}},
      {"tool_2@server_form.exchange_tool_button": {"grid_position": [0, 1], "collection_index": 39}},
      {"tool_3@server_form.exchange_tool_button": {"grid_position": [1, 1], "collection_index": 40}},
      {"tool_4@server_form.exchange_tool_button": {"grid_position": [0, 2], "collection_index": 41}},
      {"tool_5@server_form.exchange_tool_button": {"grid_position": [1, 2], "collection_index": 42}},
      {"tool_6@server_form.exchange_tool_button": {"grid_position": [0, 3], "collection_index": 43}}
    ]
  },
  "exchange_trade_slots": {
    "type": "stack_panel",
    "size": [154, 76],
    "orientation": "vertical",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "collection_name": "form_buttons",
    "controls": [
      {"trade_0@server_form.exchange_trade_button": {"collection_index": 44}},
      {"trade_1@server_form.exchange_trade_button": {"collection_index": 45}},
      {"trade_2@server_form.exchange_trade_button": {"collection_index": 46}},
      {"trade_3@server_form.exchange_trade_button": {"collection_index": 47}},
      {"trade_4@server_form.exchange_trade_button": {"collection_index": 48}}
    ]
  },
  "exchange_side_button@server_form.exchange_visible_slot": {
    "size": ["100%", 27],
    "$slot_controls": [
      {
        "hit@server_form.exchange_hit_button": {
          "size": [72, 24],
          "offset": [1, 1]
        }
      },
      {
        "icon@server_form.exchange_button_icon": {
          "size": [18, 18],
          "offset": [4, 4]
        }
      },
      {
        "label@server_form.exchange_button_label": {
          "size": [48, 19],
          "offset": [23, 4],
          "$label_scale": 0.72,
          "$label_alignment": "left"
        }
      }
    ]
  },
  "exchange_product_button@server_form.exchange_visible_slot": {
    "size": [64, 36],
    "$slot_controls": [
      {
        "hit@server_form.exchange_hit_button": {
          "size": [60, 33],
          "offset": [2, 1]
        }
      },
      {
        "icon@server_form.exchange_button_icon": {
          "size": [21, 21],
          "offset": [21, 3]
        }
      },
      {
        "label@server_form.exchange_button_label": {
          "size": [58, 10],
          "offset": [3, 25],
          "$label_scale": 0.55,
          "$label_alignment": "center"
        }
      }
    ]
  },
  "exchange_tool_button@server_form.exchange_visible_slot": {
    "size": [77, 18],
    "$slot_controls": [
      {
        "hit@server_form.exchange_hit_button": {
          "size": [73, 17],
          "offset": [2, 0]
        }
      },
      {
        "icon@server_form.exchange_button_icon": {
          "size": [12, 12],
          "offset": [5, 3]
        }
      },
      {
        "label@server_form.exchange_button_label": {
          "size": [53, 13],
          "offset": [19, 3],
          "$label_scale": 0.62,
          "$label_alignment": "left"
        }
      }
    ]
  },
  "exchange_trade_button@server_form.exchange_visible_slot": {
    "size": ["100%", 15],
    "$slot_controls": [
      {
        "hit@server_form.exchange_hit_button": {
          "size": [150, 14],
          "offset": [2, 0]
        }
      },
      {
        "icon@server_form.exchange_button_icon": {
          "size": [11, 11],
          "offset": [6, 2]
        }
      },
      {
        "label@server_form.exchange_button_label": {
          "size": [126, 12],
          "offset": [20, 2],
          "$label_scale": 0.62,
          "$label_alignment": "left"
        }
      }
    ]
  },
  "exchange_visible_slot": {
    "type": "panel",
    "collection_name": "form_buttons",
    "$slot_controls": [],
    "controls": "$slot_controls",
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons",
        "binding_name_override": "#slot_text"
      },
      {
        "binding_name": "#form_button_texture",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons",
        "binding_name_override": "#slot_texture"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#slot_text = '') and (#slot_texture = '')))",
        "target_property_name": "#visible"
      }
    ]
  },
  "exchange_hit_button@common_buttons.light_text_button": {
    "$pressed_button_name": "button.form_button_click",
    "$button_text": "",
    "$button_text_binding_type": "none",
    "$button_binding_condition": "once",
    "layer": 1,
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      }
    ]
  },
  "exchange_button_icon": {
    "type": "image",
    "layer": 5,
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_texture",
        "binding_name_override": "#texture",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_texture_file_system",
        "binding_name_override": "#texture_file_system",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#texture = '') or (#texture = 'loading')))",
        "target_property_name": "#visible"
      }
    ]
  },
  "exchange_button_label": {
    "type": "label",
    "layer": 6,
    "color": "$main_header_text_color",
    "font_size": "small",
    "font_scale_factor": "$label_scale",
    "text_alignment": "$label_alignment",
    "text": "#form_button_text",
    "$label_scale|default": 0.65,
    "$label_alignment|default": "center",
    "bindings": [
      {
        "binding_type": "collection_details",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_name": "#form_button_text",
        "binding_type": "collection",
        "binding_collection_name": "form_buttons"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#form_button_text = ''))",
        "target_property_name": "#visible"
      }
    ]
  }
}
